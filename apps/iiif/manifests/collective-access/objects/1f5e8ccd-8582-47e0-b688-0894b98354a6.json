                "en": [
                    "Documentation"
                ],
                "nl": [
                    "Documentatie"
                ]
            },
            "value": {
                "nl": [
                    "Giersbergen, Wilma van, \"Universitair cultureel erfgoed. Zes negentiende-eeuwse waterstaatswerken geschilderd door C.C. Kannemans en A.W. Stortenbeker\", in: 'Delft Integraal', nr. 4, 1998, pp. 22-25."
                ]
            }
